# Backend del Agente de Selección (FastAPI + bot Telegram + LangGraph + RAG).
# Imagen Linux CPU-only: corre en cualquier SO con Docker, sin los pins de Mac Intel.
FROM python:3.12-slim

# libgomp1: OpenMP que necesitan torch y onnxruntime en runtime.
RUN apt-get update && apt-get install -y --no-install-recommends libgomp1 \
    && rm -rf /var/lib/apt/lists/*

ENV PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    HF_HOME=/models

WORKDIR /app

# uv para instalar dependencias (más rápido que pip).
RUN pip install --no-cache-dir uv

# torch CPU de Linux ANTES del resto: el pin torch==2.2.2 del pyproject se resuelve
# contra el índice CPU de PyTorch (2.2.2+cpu) y evita arrastrar el wheel CUDA (~2 GB).
RUN uv pip install --system torch==2.2.2 --index-url https://download.pytorch.org/whl/cpu

# Dependencias de runtime desde pyproject (sin extra dev: pytest no viaja a prod).
# El proyecto no se instala como paquete (módulos top-level + WORKDIR): solo sus deps.
COPY pyproject.toml .
RUN uv pip install --system -r pyproject.toml

# Código del backend (el frontend tiene su propia imagen).
COPY api/ ./api/
COPY agente/ ./agente/
COPY retrieval/ ./retrieval/
COPY ranking/ ./ranking/
COPY orquestacion/ ./orquestacion/
COPY adaptadores_mcp/ ./adaptadores_mcp/
COPY observabilidad/ ./observabilidad/
COPY core/ ./core/
COPY channels/ ./channels/
COPY db/ ./db/
COPY evaluation/ ./evaluation/
COPY integrations/ ./integrations/
COPY notifications/ ./notifications/
COPY scripts/ ./scripts/

# Datos en runtime: uploads/ (staging de documentos) y chroma_db/ (RAG) se montan
# como volúmenes en compose/K8s para sobrevivir redeploys.
RUN mkdir -p uploads chroma_db

EXPOSE 8000

# Healthcheck sin curl (slim): urllib contra /api/health.
HEALTHCHECK --interval=30s --timeout=5s --start-period=30s --retries=3 \
    CMD python -c "import urllib.request,sys; sys.exit(0 if urllib.request.urlopen('http://localhost:8000/api/health', timeout=4).status==200 else 1)"

CMD ["uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8000"]
