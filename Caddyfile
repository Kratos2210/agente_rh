# Reverse proxy: única entrada (puerto 80 dentro de la red Docker).
# Rutea /api/* directo al backend (SSE/streaming-safe) y el resto al frontend.
# Evita el proxy interno de Next.js, que en producción corta el streaming SSE.
:80 {
	handle /api/* {
		reverse_proxy backend:8000
	}
	handle {
		reverse_proxy frontend:3000
	}
}
