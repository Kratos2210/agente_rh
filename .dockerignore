# Lo que NO entra a las imágenes (se regenera o es secreto/innecesario).
.git
.gitignore
.venv
venv
**/__pycache__
*.pyc
.pytest_cache
.ruff_cache
.mypy_cache
.DS_Store

# Frontend: se reinstala/reconstruye dentro de la imagen.
frontend/node_modules
frontend/.next

# Secretos: el .env real NUNCA va a la imagen (compose lo inyecta como env_file).
.env

# Datos de runtime: viven en volúmenes (compose) o PVCs (K8s), no en la imagen.
chroma_db
uploads
models

# Desarrollo / documentación: no aplican en runtime.
tests
docs
supabase
deploy
.github
.claude
CLAUDE.md
uv.lock
*.log
