# Copiá este archivo a .env y completá tus valores.

# ── LLM (API compatible con OpenAI) ───────────────────────────────────────────
# Groq:   https://api.groq.com/openai/v1   (qwen/qwen3-32b, llama-3.1-8b-instant...)
# AI Gateway (Vercel): https://ai-gateway.vercel.sh/v1
# OpenAI: https://api.openai.com/v1
OPENAI_API_BASE=https://api.groq.com/openai/v1
OPENAI_API_KEY=tu_api_key_aqui
OPENAI_MODEL=qwen/qwen3-32b
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2
# Optimización de costos (paso 5). Modelo barato para etapas simples (mismo proveedor).
# Vacío = todo con OPENAI_MODEL. Ver docs/adr-seleccion-modelo.md.
# Validado contra el banco de aceptación golden (classify 7/7 + slot 6/6):
#   uv run python scripts/golden_eval.py --model llama-3.1-8b-instant --suite classify
#   uv run python scripts/golden_eval.py --model llama-3.1-8b-instant --suite slot
LLM_CHEAP_MODEL=llama-3.1-8b-instant
LLM_CHEAP_STAGES=classify,schedule
# Caché semántica de dudas del candidato (0 tokens en preguntas repetidas por vacante).
INTERVIEW_ANSWER_CACHE_ENABLED=false
INTERVIEW_ANSWER_CACHE_DB=./answer_cache.db

# ── Supabase (persistencia de negocio) ────────────────────────────────────────
# Opción A — LOCAL (Docker, `supabase start`): valores fijos que imprime la CLI.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_KEY=  # service_role key que muestra `supabase start` / `supabase status`
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
#
# Opción B — CLOUD (supabase.com): Project Settings → API / Database → Connection string.
# SUPABASE_URL=https://xxxxxxxx.supabase.co
# SUPABASE_SERVICE_KEY=tu_service_role_key
# DATABASE_URL=postgresql://postgres:password@db.xxxxxxxx.supabase.co:5432/postgres

# ── Auth del dashboard (Fase 0: cimientos SaaS) ───────────────────────────────
# Secreto para firmar los JWT. CÁMBIALO en producción (>= 32 bytes). En blanco usa
# un valor de desarrollo inseguro. Genera uno con: openssl rand -base64 48
JWT_SECRET=
# Rotación grácil (F5): al rotar JWT_SECRET, pon aquí el valor ANTERIOR (CSV) para no
# cerrar las sesiones vivas durante ~JWT_EXPIRE_MINUTES; luego vacíalo. Ver
# docs/gestion_secretos.md. Nunca se firma con estos; solo se aceptan al validar.
JWT_SECRET_PREVIOUS=
# Duración del token de sesión, en minutos (default 720 = 12 h).
JWT_EXPIRE_MINUTES=720
# Admin inicial: el backend lo crea al arrancar si la tabla `users` está vacía.
# Cambia la contraseña tras el primer login.
ADMIN_EMAIL=admin@datawith.ai
ADMIN_PASSWORD=admin1234
ADMIN_NAME=Administrador
# Orígenes permitidos por CORS (CSV). En producción, el dominio real del dashboard.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Servidor MCP (Model Context Protocol) ─────────────────────────────────────
# Expone herramientas READ-ONLY del agente en /mcp (streamable HTTP, mismo proceso)
# para clientes LLM externos (Claude Code/Desktop, etc.). Requiere el MISMO JWT del
# dashboard (Authorization: Bearer <token de /api/auth/login>) y respeta tenant+rol.
# Conectar: claude mcp add --transport http leia http://localhost:8000/mcp/ \
#            --header "Authorization: Bearer <token>"
MCP_ENABLED=false

# ── Pipeline LLM ──────────────────────────────────────────────────────────────
# RAG en las dudas del candidato: responde con fragmentos de la base de conocimiento
# (Chroma en PERSIST_DIRECTORY, colección COMPANY_KB_COLLECTION) además del company_info
# de la vacante. Sembrar el corpus: `uv run python scripts/seed_company_kb.py`.
# Carga lazy en la primera duda (torch tarda ~90 s en Mac Intel); sin corpus degrada
# con gracia a company_info plano.
INTERVIEW_RAG_ENABLED=true
COMPANY_KB_COLLECTION=company_kb

# ── Canal Telegram (demo) ─────────────────────────────────────────────────────
# Token de @BotFather. Si está vacío, el bot no arranca.
TELEGRAM_BOT_TOKEN=
# chat_ids permitidos separados por coma. Vacío = cualquiera puede usar el bot.
TELEGRAM_ALLOWED_USERS=
# Username público del bot (sin @). Habilita el deep-link por vacante en el dashboard:
# t.me/<bot>?start=<vacancy_id> — así cada aviso enruta a SU vacante (multi-tenant).
TELEGRAM_BOT_USERNAME=
# Modo webhook (paso 3). VACÍO = polling (dev local, un consumidor por token). Con la URL
# pública base del backend, el bot registra webhook en {URL}/telegram/webhook y habilita
# replicas>1 + rolling/canary. Requiere HTTPS accesible por Telegram (ingress/proxy).
TELEGRAM_WEBHOOK_URL=
# Secreto que valida los POST de Telegram (header X-Telegram-Bot-Api-Secret-Token). Vacío en
# modo webhook = se deriva del token del bot. [A-Za-z0-9_-], 1–256 chars.
TELEGRAM_WEBHOOK_SECRET=

# ── Reporte al reclutador (SMTP) ──────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASSWORD=tu_app_password
SMTP_FROM=tu_correo@gmail.com
RECRUITER_EMAIL=reclutador@empresa.com
# Destino de equipo para alertas operativas/SLA/presupuesto (paso 3). Fallback cuando un
# tenant no define notify_email; en prod, apuntar a un correo/canal de equipo, no personal.
OPS_ALERT_EMAIL=

# ── Gobierno de turnos del bot (rate limiting, auditoría R2) ──────────────────
# Cada mensaje del candidato cuesta llamadas LLM. Cooldown mínimo entre mensajes
# procesados del mismo chat (segundos; 0 = off) y tope de turnos por chat y día
# (0 = sin tope). El login del dashboard ya tiene su propio límite (5/min por IP).
BOT_TURN_COOLDOWN_SECONDS=2.0
BOT_MAX_TURNS_PER_DAY=120

# ── Documentos y limpieza técnica ─────────────────────────────────────────────
# Tamaño máximo (bytes) cuyo contenido de CV/CUL se replica en Postgres (audit D2);
# sobre el umbral el PDF queda solo en disco (uploads/). Default 5 MB.
DOCUMENT_DB_MAX_BYTES=5242880
# Purga de checkpoints LangGraph de conversaciones terminales con más de N días
# sin actividad (audit D4). 0 = desactivada.
CHECKPOINT_RETENTION_DAYS=30

# ── Parámetros de entrevista y evaluación ─────────────────────────────────────
# Máximo de follow-ups por pregunta ante respuestas vagas.
INTERVIEW_MAX_FOLLOW_UPS=1
# Umbrales del semáforo sobre el score total (0-100).
SEMAPHORE_GREEN_MIN=75
SEMAPHORE_YELLOW_MIN=50

# ── Sourcing, pre-filtro y contacto automático ────────────────────────────────
# Conector de postulantes: "simulated" (fixture Bumeran) — a futuro "bumeran"/"linkedin".
SOURCING_PROVIDER=simulated
# El CV se considera apto si pre_score >= este umbral (0-100).
PRESCREEN_PASS_MIN=60
# Flujo del producto: al sincronizar, contactar al instante por Telegram a los aptos nuevos.
# Idempotente. Poné false para volver al contacto manual con el botón del dashboard.
AUTO_CONTACT_ON_PASS=true
# Telegram no permite iniciar chat con quien no hizo /start; al contactar un apto sin chat real
# se redirige a este chat para probar el flujo en tu Telegram (demo).
DEMO_TELEGRAM_CHAT_ID=

# ── Agendamiento de entrevista (fase 2) ───────────────────────────────────────
# "simulated" (default, sin credenciales): reclutador libre + enlace Meet falso + CSV local.
# "google": Calendar free/busy + evento Meet real + invitación por correo.
SCHEDULING_PROVIDER=simulated
# Opción A — Gmail PERSONAL: OAuth de usuario (genera Meet real + invitaciones).
#   1) GCP Console: habilita Calendar API + crea credenciales OAuth "App de escritorio".
#   2) Descarga el client_secret.json y apunta GOOGLE_OAUTH_CLIENT_PATH aquí.
#   3) `uv run python scripts/google_oauth.py` → autoriza en el navegador → genera el token.
GOOGLE_OAUTH_CLIENT_PATH=secrets/client_secret.json
GOOGLE_OAUTH_TOKEN_PATH=secrets/token.json
# Opción B — Google WORKSPACE: cuenta de servicio + Domain-Wide Delegation.
GOOGLE_CREDENTIALS_PATH=
# Opcional (ambas opciones): registro de reuniones en un Google Sheet.
MEETING_SHEET_ID=
MEETING_SHEET_TAB=Reuniones

# ── Observabilidad (opcional) ─────────────────────────────────────────────────
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=agente-rh

# Arize Phoenix (observabilidad LLM, OpenInference/OTel) — SELF-HOSTED para que la
# PII no salga (Ley 29733): docker run -p 6006:6006 arizephoenix/phoenix
# Con enabled=true las llamadas LangChain emiten spans (prompt/respuesta/latencia).
PHOENIX_ENABLED=false
PHOENIX_ENDPOINT=http://localhost:6006/v1/traces
PHOENIX_PROJECT=agente-rh
# Trazas LLM propias (O-1): guarda prompt/respuesta POR LLAMADA en la tabla
# `llm_traces` (replay/debug de evaluaciones; visibles solo para admin en el
# detalle del candidato). Off por default: los prompts llevan PII del candidato —
# retención y erasure las purgan junto al resto.
LLM_TRACE_ENABLED=false
LLM_TRACE_MAX_CHARS=8000
# Logs estructurados (O-6): una línea JSON por evento (ts/level/logger/message/
# request_id) — para agregadores tipo Loki/CloudWatch. El request_id viaja también
# en el header X-Request-ID de cada respuesta de la API.
LOG_JSON=false
# Error tracking (O-6, config-gated): sin DSN, Sentry no se inicializa
# (send_default_pii=false: solo stacktraces, sin datos del candidato).
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
# Snapshot periódico de las métricas HTTP a la DB (O-6): historial de rendimiento
# que sobrevive redeploys (tabla http_metrics_snapshots). 0 = apagado.
HTTP_SNAPSHOT_MINUTES=60
HTTP_SNAPSHOT_RETENTION_DAYS=14

# ── RAG: base de conocimiento de la empresa ───────────────────────────────────
# El agente responde dudas del candidato sobre el puesto citando estos documentos
# (Chroma local + embeddings HuggingFace, igual que agente_pro).
PERSIST_DIRECTORY=./chroma_db
EMBEDDING_MODEL=intfloat/multilingual-e5-base
RERANKER=cross
# Cross-encoder LIVIANO multilingüe (rápido en CPU). NO usar el default pesado
# (BAAI/bge-reranker-v2-m3): ~5 min/consulta sin GPU.
CROSS_ENCODER_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
CHUNK_SIZE=1600
CHUNK_OVERLAP=200
RETRIEVE_K=10
FINAL_K=6
